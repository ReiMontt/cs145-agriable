# AgriAble environment template
# Copy this file to .env and fill in your local values.
# NOTE: For .pem/.p12/wg0.conf, store FILE PATHS here (not file contents).

# ---------- Backend ----------
SUPABASE_URL=
SUPABASE_KEY=

# ---------- MOSIP core ----------
MOSIP_PARTNER_ID=
MOSIP_PARTNER_APIKEY=
MOSIP_PARTNER_MISP_LK=
MOSIP_AUTH_DOMAIN_URI=https://api-internal.pdec.mosip.net
MOSIP_AUTH_URL=https://api-internal.pdec.mosip.net/idauthentication/v1
MOSIP_AUTH_ENV=Staging

# ---------- Certificate / key file paths ----------
# Example: ./secrets/mosip/pdec_ida_partner.pem
MOSIP_ENCRYPT_CERT_PATH=
# Example: ./secrets/mosip/keystore.p12
MOSIP_DECRYPT_P12_PATH=
MOSIP_DECRYPT_P12_PASSWORD=
# Example: ./secrets/mosip/keystore-signed.p12
MOSIP_SIGN_P12_PATH=
MOSIP_SIGN_P12_PASSWORD=

# ---------- WireGuard file path ----------
# Example: ./secrets/wireguard/wg0.conf
WG_CONFIG_PATH=

# ---------- Frontend ----------
VITE_API_URL=http://localhost:8000
